# Copy to .env and fill in. Never commit .env.

# --- EC2 / n8n ---
N8N_HOST=localhost
TZ=UTC
N8N_USER=admin
N8N_PASSWORD=change-me-please

# --- LiteLLM master key (generate any random string, e.g. openssl rand -hex 32) ---
LITELLM_MASTER_KEY=change-me-litellm-key

# --- Model backend: fill in the one you use, leave others blank ---

# OpenRouter (recommended — one key, swap models in litellm_config.yaml)
OPENROUTER_API_KEY=

# Anthropic direct (uncomment Option B in litellm_config.yaml)
ANTHROPIC_API_KEY=

# Ollama: no key needed — uncomment the ollama service + Option C in litellm_config.yaml