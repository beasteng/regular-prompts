# Copy to .env and fill in. Never commit .env.

# ============================================================
# EC2 / n8n
# ============================================================
N8N_HOST=localhost
TZ=UTC
N8N_USER=admin
N8N_PASSWORD=change-me-please
N8N_API_KEY=test-n8n-api-key

# ============================================================
# LiteLLM
# ============================================================
LITELLM_MASTER_KEY=change-me-litellm-key
DATABASE_URL=postgresql://litellm:litellm_pass@postgres:5432/litellm

# ============================================================
# S3 / Storage — two modes, see instructions below
# ============================================================

# --- Active bucket & region (used by both MinIO and real S3) ---
S3_BUCKET=rendered-html
AWS_REGION=us-east-1

# --- MODE A: MinIO (default — comment this block out for real S3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-change-me
# Internal Docker endpoint seen by n8n. Keep this set for MinIO mode.
S3_ENDPOINT=http://minio:9000
# MinIO uses its root credentials as the "AWS" key pair
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin-change-me

# --- MODE B: Real AWS S3 ---
# To switch:
#   1. Fill in the three vars below.
#   2. Comment out the MinIO block above.
#   3. Comment out the `minio` service in docker-compose.yml.
#   4. Leave S3_ENDPOINT blank (empty string) so n8n hits real AWS.
#   5. Comment out `depends_on` inside `s3-init` in docker-compose.yml
#      (s3-init will still run and create the bucket on real AWS)
#
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# S3_ENDPOINT=

# ============================================================
# Model backends — fill in the one you use
# ============================================================
OPENROUTER_API_KEY=

# Anthropic direct (uncomment Option B in litellm_config.yaml)
ANTHROPIC_API_KEY=

# Google AI Studio — used by Option D (Gemini googling) and Option E (Gemini Flash) in litellm_config.yaml
GEMINI_API_KEY=

# Ollama: no key needed — uncomment the ollama service + Option C in litellm_config.yaml
